# ── Taktill POS — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values.
# In production, set these as host environment variables.
# For Vercel deployment, add these in the Vercel Dashboard (Settings → Environment Variables).

# Database connection (PostgreSQL / Neon)
# For local SQLite dev, use: DATABASE_FILE="taktill.db"
DATABASE_URL="postgresql://user:pass@host:5432/taktill?sslmode=require"

# Better Auth secret (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET="change-me-to-a-random-64-char-hex-string"

# API port
API_PORT="8787"

# App URL (used by Better Auth for redirects)
APP_URL="http://localhost:5173"

# Email (for password reset — optional in MVP)
EMAIL_FROM="noreply@taktill.app"
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
